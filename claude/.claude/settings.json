{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(terraform *)",
      "mcp__plugin_context7_context7__query-docs",
      "mcp__plugin_context7_context7__resolve-library-id",
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(aws:*)",
      "Skill(playwright-cli)",
      "WebSearch",
      "WebFetch(domain:gitlab.com)",
      "WebFetch(domain:github.com)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(terraform apply:*)"
    ],
    "defaultMode": "default"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "pkill say 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/speak_summary.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Basso.aiff"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); current_dir=$(echo \"$input\" | jq -r '.workspace.current_dir'); model=$(echo \"$input\" | jq -r '.model.display_name'); cd \"$current_dir\" 2>/dev/null; branch=$(git branch --show-current 2>/dev/null || echo 'no-git'); aws_profile=\"\"; [ -n \"$AWS_PROFILE\" ] && aws_profile=$(printf \" \\033[33m[aws:%s]\\033[0m\" \"$AWS_PROFILE\"); printf \"\\033[36m%s\\033[0m \\033[32m(%s)\\033[0m%s \\033[35m%s\\033[0m\" \"$(basename \"$current_dir\")\" \"$branch\" \"$aws_profile\" \"$model\""
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "context7@claude-plugins-official": true
  },
  "outputStyle": "Explanatory",
  "alwaysThinkingEnabled": true,
  "skipDangerousModePermissionPrompt": true
}
